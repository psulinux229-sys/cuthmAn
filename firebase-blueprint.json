{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["firstName", "lastName", "email", "role", "createdAt", "updatedAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A strategic goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "progress": { "type": "number" },
        "description": { "type": "string" },
        "deadline": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "invalid"] },
        "milestones": { 
          "type": "array", 
          "items": { "type": "object" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "category", "progress", "status", "milestones", "notes", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/goals/{goalId}": {
      "schema": { "$ref": "Goal" },
      "description": "User strategic goals"
    }
  }
}
